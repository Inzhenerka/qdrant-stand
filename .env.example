# Скопируйте в .env и заполните. docker-compose подхватит автоматически.

# Build-time: нужен для `docker compose build` (векторизация корпуса через OpenAI API).
OPENAI_API_KEY=sk-replace-me

# Runtime: переопределяют ENV из Dockerfile при `docker compose up`.
# Для прода сгенерируйте случайный мастер-ключ: openssl rand -hex 32
QDRANT_API_KEY=admin-rotate-me
QDRANT_READ_ONLY_API_KEY=student
